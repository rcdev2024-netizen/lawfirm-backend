# ============================================================
# Atty Rochelle Law Office — Environment Variables
# ============================================================
# Local development: copy this file to .env and fill in values.
# Production (Vercel): add each variable in the Vercel dashboard
#   under Project → Settings → Environment Variables.
#
# The same Supabase project is used for both local and production.
# ============================================================

# Supabase
SUPABASE_URL=https://<your-project-id>.supabase.co
SUPABASE_SERVICE_KEY=<your-supabase-service-role-key>

# JWT
SECRET_KEY=<a-long-random-secret-string>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS — comma-separated list of allowed origins
# Local:      http://localhost:4200
# Production: https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:4200
